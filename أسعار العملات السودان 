<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>مراقب الجنيه السوداني</title>
<meta name="description" content="متابعة أسعار الجنيه السوداني مقابل 9 عملات عالمية" />
<meta name="theme-color" content="#12151C" />
<link rel="manifest" href="manifest.json" />
<link rel="icon" href="icon-192.png" />
<link rel="apple-touch-icon" href="icon-192.png" />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@700;800;900&family=IBM+Plex+Sans+Arabic:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#12151C; --bgPanel:#181C25; --bgCard:#1D2230; --line:#2A3040;
    --gold:#C9A227; --goldSoft:#8A7332; --teal:#3C8C99;
    --cream:#EDEAE0; --creamDim:#9AA0AE; --up:#4FAE73; --down:#DB5A56;
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--cream);font-family:'IBM Plex Sans Arabic',sans-serif;}
  .num{font-family:'IBM Plex Mono',monospace;font-variant-numeric:tabular-nums;direction:ltr;unicode-bidi:isolate;}
  .display{font-family:'Cairo',sans-serif;}
  .wrap{max-width:1150px;margin:0 auto;padding:28px 18px;}
  .ticker{background:var(--bgPanel);border-bottom:1px solid var(--line);overflow:hidden;padding:8px 0;}
  .ticker-track{display:flex;white-space:nowrap;width:200%;animation:marquee 38s linear infinite;}
  .ticker-half{display:flex;width:50%;}
  .ticker-item{display:flex;align-items:center;gap:8px;padding:0 20px;font-size:14px;flex-shrink:0;}
  @keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
  .head{display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:28px;}
  .live-row{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
  .dot{width:8px;height:8px;border-radius:50%;background:var(--up);animation:pulse 1.6s ease-in-out infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}
  h1{font-size:32px;font-weight:900;margin:0;}
  .sub{color:var(--creamDim);font-size:14px;margin-top:4px;}
  .clock{text-align:left;}
  .clock .time{color:var(--gold);font-size:18px;font-weight:600;}
  .clock .date{color:var(--creamDim);font-size:13px;}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-bottom:36px;}
  .card{background:var(--bgCard);border:1px solid var(--line);border-radius:16px;padding:20px;display:flex;flex-direction:column;gap:12px;}
  .card-top{display:flex;align-items:center;justify-content:space-between;}
  .card-id{display:flex;align-items:center;gap:8px;}
  .flag{font-size:24px;}
  .cname{font-weight:600;font-size:14px;}
  .ccode{color:var(--creamDim);font-size:12px;}
  .badge{font-size:12px;padding:4px 10px;border-radius:999px;font-weight:600;}
  .card-bottom{display:flex;align-items:flex-end;justify-content:space-between;}
  .price{font-size:24px;font-weight:600;}
  .cols{display:grid;grid-template-columns:2fr 3fr;gap:20px;}
  @media(max-width:860px){.cols{grid-template-columns:1fr;}}
  .panel{background:var(--bgCard);border:1px solid var(--line);border-radius:16px;padding:22px;}
  .panel h2{font-size:17px;margin:0 0 16px;color:var(--gold);}
  label{font-size:12px;color:var(--creamDim);}
  input,select{width:100%;margin-top:4px;border-radius:10px;padding:9px 10px;background:var(--bg);border:1px solid var(--line);color:var(--cream);font-size:15px;}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0;}
  .swap{font-size:12px;padding:6px 12px;border-radius:999px;border:1px solid var(--line);color:var(--creamDim);background:transparent;cursor:pointer;margin-bottom:14px;}
  .result{border-radius:12px;padding:14px;background:var(--bg);border:1px solid var(--goldSoft);}
  .result .lbl{font-size:12px;color:var(--creamDim);margin-bottom:4px;}
  .result .val{font-size:22px;font-weight:700;color:var(--gold);}
  table{width:100%;border-collapse:collapse;font-size:14px;}
  th{text-align:right;color:var(--creamDim);font-weight:500;padding:8px 0;border-bottom:1px solid var(--line);}
  td{padding:9px 0;border-bottom:1px solid var(--line);}
  .foot{text-align:center;color:var(--creamDim);font-size:12px;margin-top:28px;}
  svg{overflow:visible;}
</style>
</head>
<body>
<div class="ticker"><div class="ticker-track" id="tickerTrack"></div></div>

<div class="wrap">
  <div class="head">
    <div>
      <div class="live-row"><span class="dot"></span><span class="num" style="color:var(--creamDim);font-size:12px;">مباشر · تحديث تلقائي</span></div>
      <h1 class="display">مراقب الجنيه السوداني</h1>
      <div class="sub">أسعار السوق الموازي التقديرية مقابل 9 عملات</div>
    </div>
    <div class="clock">
      <div class="time num" id="clockTime"></div>
      <div class="date" id="clockDate"></div>
    </div>
  </div>

  <div class="grid" id="cardsGrid"></div>

  <div class="cols">
    <div class="panel">
      <h2 class="display">محوّل العملات</h2>
      <label>المبلغ</label>
      <input type="number" id="amount" class="num" value="100" />
      <div class="row2">
        <div>
          <label>من</label>
          <select id="fromCode"></select>
        </div>
        <div>
          <label>إلى</label>
          <select id="toCode"></select>
        </div>
      </div>
      <button class="swap" id="swapBtn">⇄ عكس الاتجاه</button>
      <div class="result">
        <div class="lbl">النتيجة</div>
        <div class="val num" id="resultVal">—</div>
      </div>
    </div>

    <div class="panel" style="overflow-x:auto;">
      <h2 class="display">جدول مقارن</h2>
      <table>
        <thead><tr><th>العملة</th><th>السعر</th><th>التغير</th><th>أعلى</th><th>أدنى</th></tr></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <div class="foot">⚠️ الأسعار تقديرية ومحاكاة لأغراض العرض التوضيحي وليست بيانات سوق حية — راجع منصات الصرافة المعتمدة للأسعار الفعلية.</div>
</div>

<script>
const CURRENCIES = [
  { code:"USD", name:"دولار أمريكي", flag:"🇺🇸", base:2410 },
  { code:"GBP", name:"جنيه إسترليني", flag:"🇬🇧", base:3070 },
  { code:"KWD", name:"دينار كويتي", flag:"🇰🇼", base:7860 },
  { code:"SAR", name:"ريال سعودي", flag:"🇸🇦", base:642 },
  { code:"AED", name:"درهم إماراتي", flag:"🇦🇪", base:656 },
  { code:"QAR", name:"ريال قطري", flag:"🇶🇦", base:662 },
  { code:"EGP", name:"جنيه مصري", flag:"🇪🇬", base:49.5 },
  { code:"EUR", name:"يورو", flag:"🇪🇺", base:2615 },
  { code:"UGX", name:"شلن أوغندي", flag:"🇺🇬", base:0.645 },
];
const HIST_LEN = 36;
const state = {};
CURRENCIES.forEach(c=>{
  let v=c.base; const hist=[];
  for(let i=0;i<HIST_LEN;i++){ v=v*(1+(Math.random()-0.5)*0.006); hist.push(v); }
  state[c.code]={value:v, hist};
});

function fmt(n, decimals){
  const d = decimals ?? (n<10?3:n<100?2:0);
  return n.toLocaleString("en-US",{minimumFractionDigits:d,maximumFractionDigits:d});
}

function sparklineSVG(hist, color, w=108, h=34){
  const min=Math.min(...hist), max=Math.max(...hist), range=(max-min)||1;
  const pts = hist.map((v,i)=>{
    const x=(i/(hist.length-1))*w;
    const y=h-((v-min)/range)*h;
    return x.toFixed(1)+","+y.toFixed(1);
  });
  const path="M"+pts.join(" L");
  const areaPath=`${path} L${w},${h} L0,${h} Z`;
  const gid="g"+Math.random().toString(36).slice(2);
  return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">
    <defs><linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${color}" stop-opacity="0.35"/>
      <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="${areaPath}" fill="url(#${gid})" stroke="none"/>
    <path d="${path}" fill="none" stroke="${color}" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/>
  </svg>`;
}

function buildTicker(){
  const track=document.getElementById("tickerTrack");
  let html="";
  for(let rep=0; rep<2; rep++){
    html+=`<div class="ticker-half">`;
    CURRENCIES.forEach(c=>{
      const r=state[c.code];
      html+=`<div class="ticker-item">
        <span>${c.flag}</span>
        <span class="num" style="color:var(--creamDim);">${c.code}/SDG</span>
        <span class="num" id="tk-${c.code}-${rep}" style="font-weight:600;color:var(--up);">${fmt(r.value)}</span>
      </div>`;
    });
    html+="</div>";
  }
  track.innerHTML=html;
}

function renderCards(){
  const grid=document.getElementById("cardsGrid");
  let html="";
  CURRENCIES.forEach(c=>{
    const r=state[c.code];
    const first=r.hist[0];
    const changePct=((r.value-first)/first)*100;
    const isUp=changePct>=0;
    const color=isUp?"var(--up)":"var(--down)";
    html+=`<div class="card">
      <div class="card-top">
        <div class="card-id">
          <span class="flag">${c.flag}</span>
          <div><div class="cname">${c.name}</div><div class="ccode num">${c.code} / SDG</div></div>
        </div>
        <div class="badge num" style="color:${color};background:${isUp?'rgba(79,174,115,0.12)':'rgba(219,90,86,0.12)'}">
          ${isUp?"▲":"▼"} ${fmt(Math.abs(changePct),2)}%
        </div>
      </div>
      <div class="card-bottom">
        <div class="price num">${fmt(r.value)}</div>
        ${sparklineSVG(r.hist, isUp?"#4FAE73":"#DB5A56")}
      </div>
    </div>`;
  });
  grid.innerHTML=html;
}

function renderTable(){
  const body=document.getElementById("tableBody");
  let html="";
  CURRENCIES.forEach(c=>{
    const r=state[c.code];
    const first=r.hist[0];
    const changePct=((r.value-first)/first)*100;
    const isUp=changePct>=0;
    const color=isUp?"var(--up)":"var(--down)";
    const hi=Math.max(...r.hist), lo=Math.min(...r.hist);
    html+=`<tr>
      <td>${c.flag} ${c.name}</td>
      <td class="num">${fmt(r.value)}</td>
      <td class="num" style="color:${color};font-weight:600;">${isUp?"▲":"▼"} ${fmt(Math.abs(changePct),2)}%</td>
      <td class="num" style="color:var(--creamDim);">${fmt(hi)}</td>
      <td class="num" style="color:var(--creamDim);">${fmt(lo)}</td>
    </tr>`;
  });
  body.innerHTML=html;
}

function populateSelects(){
  const opts=[{code:"SDG",name:"جنيه سوداني",flag:"🇸🇩"},...CURRENCIES];
  const fromSel=document.getElementById("fromCode");
  const toSel=document.getElementById("toCode");
  opts.forEach(o=>{
    fromSel.innerHTML+=`<option value="${o.code}">${o.flag} ${o.code}</option>`;
    toSel.innerHTML+=`<option value="${o.code}">${o.flag} ${o.code}</option>`;
  });
  fromSel.value="USD"; toSel.value="SDG";
}

function convert(){
  const amount=parseFloat(document.getElementById("amount").value)||0;
  const fromCode=document.getElementById("fromCode").value;
  const toCode=document.getElementById("toCode").value;
  const fromVal = fromCode==="SDG"?1:state[fromCode].value;
  const toVal = toCode==="SDG"?1:state[toCode].value;
  const inSdg = amount*fromVal;
  const result = inSdg/toVal;
  document.getElementById("resultVal").textContent = fmt(result,2)+" "+toCode;
}

function updateClock(){
  const now=new Date();
  document.getElementById("clockTime").textContent = now.toLocaleTimeString("en-GB");
  document.getElementById("clockDate").textContent = now.toLocaleDateString("ar-SD",{weekday:"long",year:"numeric",month:"long",day:"numeric"});
}

function tick(){
  CURRENCIES.forEach(c=>{
    const cur=state[c.code];
    const drift=(Math.random()-0.5)*0.004;
    const value=Math.max(0.001, cur.value*(1+drift));
    cur.hist=[...cur.hist.slice(1), value];
    cur.value=value;
  });
  buildTicker(); renderCards(); renderTable(); convert();
}

document.getElementById("amount").addEventListener("input", convert);
document.getElementById("fromCode").addEventListener("change", convert);
document.getElementById("toCode").addEventListener("change", convert);
document.getElementById("swapBtn").addEventListener("click", ()=>{
  const f=document.getElementById("fromCode"), t=document.getElementById("toCode");
  const tmp=f.value; f.value=t.value; t.value=tmp; convert();
});

populateSelects();
buildTicker();
renderCards();
renderTable();
updateClock();
convert();
setInterval(updateClock, 1000);
setInterval(tick, 3200);

if("serviceWorker" in navigator){
  window.addEventListener("load", ()=>{
    navigator.serviceWorker.register("sw.js").catch(()=>{});
  });
}
</script>
</body>
</html>
